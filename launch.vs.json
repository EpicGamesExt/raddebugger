{
  "version": "0.2.1",
  "defaults": {},
  "configurations": [
    {
      "type": "cppdbg",
      "name": "raddbg",
      "request": "launch",
      "project": "c://windows//system32//cmd.exe",
      "cwd": "build/",
      "program": "torture",
      "args": [ "basic_stepping_test-c" ],
      "stopAtEntry": false,
      "environment": [],
      "externalConsole": false,
      "pipeTransport": {
        "pipeCwd": "${workspaceRoot}",
        "pipeProgram": "wsl",
        "pipeArgs": [ "${debuggerCommand}" ]
      },
      "setupCommands": [
        { "text": "handle SIGUSR1 nostop" }
      ],
      "MIMode": "gdb"
    }
  ]
}
